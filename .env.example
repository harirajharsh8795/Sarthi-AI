# Saarthi AI Production Environment Configuration
PORT=8000
ENVIRONMENT=production

# LLM / Ollama Edge AI Service
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=llama3.2:1b

# RAG & ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=saarthi_kb

# Database & Storage
SQLITE_DB_PATH=./data/sqlite/saarthi.db
BACKUP_DIR=./backups

# Jetson Orin Hardware Optimization
CUDA_VISIBLE_DEVICES=0
OMP_NUM_THREADS=4
MALLOC_TRIM_THRESHOLD_=100000

# Security & CORS
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost,http://localhost:80
